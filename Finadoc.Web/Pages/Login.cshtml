@page "/login"
@namespace Finadoc.Web.Pages
@model Finadoc.Web.Pages.LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_RazorLayout";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="brand">Finadoc</div>
        <h1>Sign in</h1>
        <p class="subtitle">Financial document analysis platform</p>

        @if (Model.ErrorMessage is not null)
        {
            <div class="alert alert-error">@Model.ErrorMessage</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label for="username">Username</label>
                <input type="text" id="username" name="username"
                       autocomplete="username" required autofocus
                       value="@Model.Username" />
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password"
                       autocomplete="current-password" required />
            </div>
            <button type="submit" class="btn btn-primary btn-full mt-3">Sign in</button>
        </form>
    </div>
</div>
