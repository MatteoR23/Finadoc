@page "/change-password"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Finadoc.Web.Auth
@using Finadoc.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IAuthProvider AuthProvider
@inject UserService UserService
@inject AuthenticationStateProvider AuthState

<PageTitle>Change Password — Finadoc</PageTitle>

<div class="page-header">
    <h1>Change Password</h1>
    <a href="/" class="btn btn-secondary">← Back</a>
</div>

@if (_success)
{
    <div class="alert alert-success">Password changed successfully.</div>
}

@if (_error is not null)
{
    <div class="alert alert-error">@_error</div>
}

@if (!_success)
{
    <EditForm Model="_model" OnValidSubmit="HandleSubmit" class="form-card">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label for="current">Current password</label>
            <InputText id="current" type="password" @bind-Value="_model.Current" autocomplete="current-password" />
            <ValidationMessage For="() => _model.Current" />
        </div>
        <div class="form-group">
            <label for="newpw">New password</label>
            <InputText id="newpw" type="password" @bind-Value="_model.NewPassword" autocomplete="new-password" />
            <ValidationMessage For="() => _model.NewPassword" />
        </div>
        <div class="form-group">
            <label for="confirm">Confirm new password</label>
            <InputText id="confirm" type="password" @bind-Value="_model.Confirm" autocomplete="new-password" />
            <ValidationMessage For="() => _model.Confirm" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary" disabled="@_submitting">
                @(_submitting ? "Saving…" : "Change password")
            </button>
            <a href="/" class="btn btn-secondary">Cancel</a>
        </div>
    </EditForm>
}

@code {
    private readonly ChangePasswordModel _model = new();
    private string? _error;
    private bool _submitting;
    private bool _success;
    private string? _username;
    private Guid _userId;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        _username = state.User.FindFirstValue(ClaimTypes.Name);
        var uid = state.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (uid is not null) Guid.TryParse(uid, out _userId);
    }

    private async Task HandleSubmit()
    {
        _error = null;

        if (_model.NewPassword != _model.Confirm)
        {
            _error = "New passwords do not match.";
            return;
        }

        if (_model.NewPassword.Length < 8)
        {
            _error = "New password must be at least 8 characters.";
            return;
        }

        if (_username is null)
        {
            _error = "Session error — please log in again.";
            return;
        }

        _submitting = true;
        try
        {
            var auth = await AuthProvider.AuthenticateAsync(_username, _model.Current);
            if (!auth.Succeeded)
            {
                _error = "Current password is incorrect.";
                _submitting = false;
                return;
            }

            await UserService.UpdatePasswordAsync(_userId, _model.NewPassword);
            _success = true;
        }
        catch (Exception ex)
        {
            _error = $"Failed to change password: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class ChangePasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Current password is required.")]
        public string Current { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "New password is required.")]
        [System.ComponentModel.DataAnnotations.MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string NewPassword { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please confirm the new password.")]
        public string Confirm { get; set; } = string.Empty;
    }
}
