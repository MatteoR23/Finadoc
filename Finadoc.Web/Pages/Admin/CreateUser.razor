@page "/admin/create-user"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "AdminOnly")]
@using Finadoc.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject UserService UserService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Create User — Finadoc</PageTitle>

<div class="page-header">
    <h1>Create User</h1>
    <a href="/admin/users" class="btn btn-secondary">← Back</a>
</div>

@if (_error is not null)
{
    <div class="alert alert-error">@_error</div>
}

<EditForm Model="_model" OnValidSubmit="HandleSubmit" class="form-card">
    <DataAnnotationsValidator />

    <div class="form-group">
        <label for="username">Username</label>
        <InputText id="username" @bind-Value="_model.Username" autocomplete="off" />
        <ValidationMessage For="() => _model.Username" />
    </div>

    <div class="form-group">
        <label for="password">Password</label>
        <InputText id="password" type="password" @bind-Value="_model.Password" autocomplete="new-password" />
        <ValidationMessage For="() => _model.Password" />
    </div>

    <div class="form-group">
        <label for="confirm">Confirm password</label>
        <InputText id="confirm" type="password" @bind-Value="_model.Confirm" autocomplete="new-password" />
        <ValidationMessage For="() => _model.Confirm" />
    </div>

    <div class="form-group">
        <label class="checkbox-label">
            <InputCheckbox @bind-Value="_model.IsAdmin" />
            Administrator
        </label>
    </div>

    <fieldset class="form-group">
        <legend>Groups</legend>
        <label class="checkbox-label">
            <input type="checkbox" @bind="_model.IsPm" />
            Portfolio Manager (PM)
        </label>
        <label class="checkbox-label">
            <input type="checkbox" @bind="_model.IsRm" />
            Risk Manager (RM)
        </label>
    </fieldset>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary" disabled="@_submitting">
            @(_submitting ? "Creating…" : "Create user")
        </button>
        <a href="/admin/users" class="btn btn-secondary">Cancel</a>
    </div>
</EditForm>

@code {
    private readonly CreateUserModel _model = new();
    private string? _error;
    private bool _submitting;
    private Guid _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var uid = state.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (uid is not null) Guid.TryParse(uid, out _currentUserId);
    }

    private async Task HandleSubmit()
    {
        _error = null;

        if (_model.Password != _model.Confirm)
        {
            _error = "Passwords do not match.";
            return;
        }

        if (_model.Password.Length < 8)
        {
            _error = "Password must be at least 8 characters.";
            return;
        }

        var groupIds = new List<int>();
        if (_model.IsPm) groupIds.Add(1);
        if (_model.IsRm) groupIds.Add(2);

        _submitting = true;
        try
        {
            await UserService.CreateUserAsync(_model.Username, _model.Password, _model.IsAdmin, groupIds, _currentUserId);
            Nav.NavigateTo("/admin/users");
        }
        catch (Exception ex)
        {
            _error = $"Failed to create user: {ex.Message}";
            _submitting = false;
        }
    }

    private sealed class CreateUserModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Username is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(64, MinimumLength = 3,
            ErrorMessage = "Username must be 3–64 characters.")]
        public string Username { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required.")]
        [System.ComponentModel.DataAnnotations.MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please confirm the password.")]
        public string Confirm { get; set; } = string.Empty;

        public bool IsAdmin { get; set; }
        public bool IsPm { get; set; }
        public bool IsRm { get; set; }
    }
}
