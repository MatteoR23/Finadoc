{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dotnet: build Finadoc.Web",
            "type": "process",
            "command": "dotnet",
            "args": ["build", "${workspaceFolder}/Finadoc.Web/Finadoc.Web.csproj"],
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: build solution",
            "type": "process",
            "command": "dotnet",
            "args": ["build", "${workspaceFolder}/Finadoc.sln"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "pip: install finadoc_ai",
            "type": "shell",
            "command": "pip install -r ${workspaceFolder}/finadoc_ai/requirements.txt",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "docker: up",
            "type": "shell",
            "command": "docker compose up --build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "docker: down",
            "type": "shell",
            "command": "docker compose down",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
