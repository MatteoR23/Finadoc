{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dotnet: build FinLens.Web",
            "type": "process",
            "command": "dotnet",
            "args": ["build", "${workspaceFolder}/FinLens.Web/FinLens.Web.csproj"],
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: build solution",
            "type": "process",
            "command": "dotnet",
            "args": ["build", "${workspaceFolder}/FinLens.sln"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "pip: install finlens_ai",
            "type": "shell",
            "command": "pip install -r ${workspaceFolder}/finlens_ai/requirements.txt",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "docker: up",
            "type": "shell",
            "command": "docker compose up --build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "docker: up (devcontainer)",
            "type": "shell",
            "command": "docker compose -f docker-compose.yml -f docker-compose.override.yml -f .devcontainer/docker-compose.devcontainer.yml up --build postgres minio minio-init ai",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "docker: down",
            "type": "shell",
            "command": "docker compose down",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
