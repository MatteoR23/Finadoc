{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FinLens Web (.NET)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "dotnet: build FinLens.Web",
            "program": "${workspaceFolder}/FinLens.Web/bin/Debug/net10.0/FinLens.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/FinLens.Web",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000",
                "Storage__DataDir": "${workspaceFolder}/data",
                "AiService__InternalApiKey": "dev-only-insecure-key"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "FinLens AI (FastAPI)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--host", "0.0.0.0",
                "--port", "8001",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/finlens_ai",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "DATA_DIR": "${workspaceFolder}/data",
                "INTERNAL_API_KEY": "dev-only-insecure-key"
            },
            "jinja": true,
            "console": "integratedTerminal"
        }
    ]
}