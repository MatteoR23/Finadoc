{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Finadoc Web (.NET)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "dotnet: build Finadoc.Web",
            "program": "${workspaceFolder}/Finadoc.Web/bin/Debug/net10.0/Finadoc.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Finadoc.Web",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Finadoc AI (FastAPI)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--host", "0.0.0.0",
                "--port", "8001",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/finadoc_ai",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "DATA_DIR": "${workspaceFolder}/data"
            },
            "jinja": true,
            "console": "integratedTerminal"
        }
    ]
}