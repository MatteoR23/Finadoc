MISTRAL_API_KEY=your_key_here
INTERNAL_API_KEY=generate_with__openssl_rand_-hex_32
MCP_CLIENT_ID=finlens-agentic
MCP_SECRET_ID=generate_with__openssl_rand_-hex_32
POSTGRES_USER=finlens
POSTGRES_PASSWORD=finlens_secret

# --- MinIO (default, local) ---
MINIO_ROOT_USER=finlens
MINIO_ROOT_PASSWORD=finlens_secret

# --- AWS S3 (external) ---
# To use S3 instead of MinIO, set these in docker-compose.yml or as env vars:
# Storage__Provider=s3
# Storage__Region=eu-south-1
# Storage__AccessKey=<aws-access-key-id>
# Storage__SecretKey=<aws-secret-access-key>
# Storage__DocumentsBucket=your-documents-bucket
# Storage__OutputsBucket=your-outputs-bucket
# (remove Storage__Endpoint and Storage__PublicEndpoint)
