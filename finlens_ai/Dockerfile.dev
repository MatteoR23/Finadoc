FROM python:3.13-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt debugpy

RUN python -m spacy download it_core_news_lg && \
    python -m spacy download en_core_web_lg

# 8000: uvicorn  5678: debugpy
EXPOSE 8000 5678

# debugpy non usa --wait-for-client: il server parte subito, l'attach è opzionale.
CMD ["python", "-m", "debugpy", "--listen", "0.0.0.0:5678", \
     "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
